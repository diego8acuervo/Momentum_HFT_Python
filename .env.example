# ============================================================================
# .env.example — template for required environment variables.
#
# Copy this file to ".env" and fill in your own credentials:
#     cp .env.example .env
#
# NEVER commit the real ".env" file. It is git-ignored on purpose.
# Each account below is consumed by src/account_manager.py.
# ============================================================================

# ── Data providers ───────────────────────────────────────────────────────────
KAIKO_API_KEY=your_kaiko_api_key_here
COINAPI_KEY=your_coinapi_key_here

# ── Binance — Live (account preset: binance_live) ────────────────────────────
# account_manager reads BINANCE_AQM_* and publishes them to BINANCE_API_KEY /
# BINANCE_SECRET_KEY (the canonical vars the live Binance trader reads).
BINANCE_AQM_API_KEY = your api key here
BINANCE_AQM_SECRET_KEY = your secret key here

# Canonical live vars (kept for backward compatibility / direct use).
# If you do NOT use the account_manager presets, set these directly instead.
BINANCE_API_KEY = your api key here
BINANCE_SECRET_KEY = your secret key here

# ── Binance — Momentum Strategy (account preset: binance_momentum) ───────────
# Separate API key for the momentum strategy so its orders don't mix with
# the mean-reversion (AQM) key's order history / position accounting.
MOMENTUM_API_KEY=your mom api key here
MOMENTUM_SECRET_KEY= your mom secret key here

# ── Binance — Testnet (account preset: binance_testnet) ──────────────────────
BINANCE_TESTNET_API_KEY=your testnet api key here
BINANCE_TESTNET_SECRET_KEY=your testnet secret key here

# ── Bitget — Live (account preset: bitget_live) ──────────────────────────────
BITGET_API_KEY=your_bitget_live_api_key
BITGET_SECRET_KEY=your_bitget_live_secret_key
BITGET_PASSPHRASE=your_bitget_live_passphrase

# ── Bitget — Paper Trading (account preset: bitget_paper) ────────────────────
# From: Bitget dashboard → Trading → Paper Trading → API Management.
BITGET_PAPER_API_KEY=your_bitget_paper_api_key
BITGET_PAPER_SECRET_KEY=your_bitget_paper_secret_key
BITGET_PAPER_PASSPHRASE=your_bitget_paper_passphrase

# Optional: override if a private Bitget testnet/demo REST URL is available.
# BITGET_TESTNET_URL=https://api.bitget.com

# ── Wallet / misc ────────────────────────────────────────────────────────────
BINANCE_USDT_POLYGONADDRESS=your_polygon_usdt_address
